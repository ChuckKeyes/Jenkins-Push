pipeline {
    agent any

    environment {
        AWS_REGION = 'us-east-1'
        S3_BUCKET  = 'jenkins-bucket-20260322204450920400000001'
    }

    stages {
        stage('Set AWS Credentials') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'larry'
                ]]) {
                    sh 'aws sts get-caller-identity'
                }
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/ChuckKeyes/Jenkins-Push.git'
            }
        }

        stage('Initialize Terraform') {
            steps {
                dir('Class-Assignments/jenkins-s3-test') {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'larry'
                    ]]) {
                        sh 'terraform init'
                    }
                }
            }
        }

        stage('Plan Terraform') {
            steps {
                dir('Class-Assignments/jenkins-s3-test') {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'larry'
                    ]]) {
                        sh 'terraform plan -out=tfplan'
                    }
                }
            }
        }

        stage('Apply Terraform') {
            steps {
                input message: "Approve Terraform Apply?", ok: "Deploy"
                dir('Class-Assignments/jenkins-s3-test') {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'larry'
                    ]]) {
                        sh 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }

        // ✅ NEW STAGE ADDED HERE
        stage('Upload Photos and README to S3') {
            steps {
                dir('Class-Assignments/jenkins-s3-test') {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'larry'
                    ]]) {
                        sh '''
                        set -eux

                        echo "=== Files in directory ==="
                        ls -lah

                        aws s3 cp photo1.jpg s3://$S3_BUCKET/uploads/photo1.jpg --region $AWS_REGION
                        aws s3 cp photo2.jpg s3://$S3_BUCKET/uploads/photo2.jpg --region $AWS_REGION
                        aws s3 cp photo3.jpg s3://$S3_BUCKET/uploads/photo3.jpg --region $AWS_REGION
                        // aws s3 cp README.md  s3://$S3_BUCKET/uploads/README.md.md  --region $AWS_REGION

                        echo "=== Uploaded Files ==="
                        aws s3 ls s3://$S3_BUCKET/uploads/ --region $AWS_REGION
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'Terraform deployment completed successfully!'
        }
        failure {
            echo 'Terraform deployment failed!'
        }
    }
}